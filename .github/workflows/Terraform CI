name: Terraform Checks

on:
  push:
    branches-ignore:
      - main
  pull_request:

jobs:
  analyze-changes:
    name: Detect Terraform Changes
    runs-on: [self-hosted, windows]
    outputs:
      terraform_changed: ${{ steps.filter.outputs.terraform }}

    steps:
      - uses: actions/checkout@v5
        with:
          fetch-depth: 0

      - name: Fetch main branch
        run: git fetch origin main

      - name: Detect Terraform changes
        id: filter
        uses: dorny/paths-filter@v3
        with:
          base: origin/main
          filters: |
            terraform:
              - '**/*.tf'
              - '**/*.tfvars'
              - '.terraform.lock.hcl'

      - name: Show results
        run: |
          echo Terraform files changed: ${{ steps.filter.outputs.terraform }}

  terraform-validate:
    name: Terraform Validate
    needs: analyze-changes
    if: needs.analyze-changes.outputs.terraform_changed == 'true'
    runs-on: [self-hosted, windows]

    steps:
      - uses: actions/checkout@v5
        with:
          fetch-depth: 0

      - name: Ensure Terraform is installed
        run: |
          if (!(Test-Path "$env:ProgramFiles\Terraform\terraform.exe")) {
            Invoke-WebRequest -Uri "https://releases.hashicorp.com/terraform/1.8.5/terraform_1.8.5_windows_amd64.zip" -OutFile "$env:TEMP\terraform.zip"
            Expand-Archive "$env:TEMP\terraform.zip" -DestinationPath "$env:ProgramFiles\Terraform"
            setx PATH "$env:ProgramFiles\Terraform;$env:PATH"
          }
        shell: pwsh

      - name: Terraform Init
        run: terraform init -backend=false
        shell: pwsh

      - name: Terraform Format Check
        run: terraform fmt -check
        shell: pwsh

      - name: Terraform Validate
        run: terraform validate -no-color
        shell: pwsh
